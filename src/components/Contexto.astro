---
import SectionContainer from '@components/SectionContainer.astro'

const mejoras = [
  {
    titulo: 'Menos quiebres de stock. Menos mermas.',
    detalle:
      'Rediseñamos el circuito de la mercadería desde que entra hasta que llega al mostrador. Puntos ciegos menos, reposición más precisa.',
  },
  {
    titulo: 'Operación pareja, sin importar el turno.',
    detalle:
      'Los procedimientos dejan de vivir en la cabeza del encargado. Están escritos, accesibles y se ejecutan igual todos los días en todas las sucursales.',
  },
  {
    titulo: 'Información al instante para quien la necesita.',
    detalle:
      'Cada empleado consulta el protocolo vigente de su área desde el celular, en segundos, sin depender de quién esté en turno.',
  },
  {
    titulo: 'Evidencia lista para certificar, cuando decidan.',
    detalle:
      'Cada acción operativa queda registrada con fecha, hora y responsable. Si el día de mañana deciden certificar ISO 9001, gran parte del trabajo ya va a estar hecho.',
  },
]
---

<SectionContainer id="contexto">
  <div class="flex flex-col gap-3">
    <span class="text-xs font-semibold uppercase tracking-[0.3em] text-teal">
      Qué les suma
    </span>
    <h2
      class="font-display text-3xl leading-tight text-navy sm:text-4xl md:text-5xl"
      style="text-wrap: balance;"
    >
      Lo que <span class="text-teal">ganan</span> trabajando con INSOLVA.
    </h2>
    <p class="mt-2 max-w-2xl text-base leading-relaxed text-navy/70">
      Cuatro mejoras concretas sobre la operación actual. No son promesas — son los ejes
      de trabajo del primer sprint.
    </p>
  </div>

  <ul class="mt-10 grid gap-5 md:grid-cols-2">
    {
      mejoras.map((m, i) => (
        <li class="group relative flex gap-5 rounded-2xl border border-navy/10 bg-white p-6 shadow-sm transition-all duration-500 hover:-translate-y-1 hover:border-teal/40 md:p-8">
          <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-teal-light font-display text-lg text-teal-dark">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div>
            <h3 class="font-semibold text-navy md:text-lg" style="text-wrap: balance;">
              {m.titulo}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-navy/65">{m.detalle}</p>
          </div>
        </li>
      ))
    }
  </ul>
</SectionContainer>
