---
import SectionContainer from '@components/SectionContainer.astro'

const bloques = [
  {
    n: '01',
    label: 'Quiénes somos',
    texto:
      'Una agencia de ingeniería que brinda servicios de optimización con base tecnológica.',
  },
  {
    n: '02',
    label: 'Con quiénes trabajamos',
    texto:
      'Con personas, profesionales independientes, negocios en expansión y empresas consolidadas que buscan reducir el riesgo ante situaciones adversas y ahorrar tiempo en tareas manuales y repetitivas.',
  },
  {
    n: '03',
    label: 'Qué obtienen',
    texto:
      'Ganar rentabilidad, reducir la incertidumbre operativa y el margen de error humano, y aumentar la escalabilidad del modelo de negocio.',
  },
]
---

<SectionContainer id="nosotros">
  <div class="rounded-3xl border border-navy/10 bg-white px-6 py-12 shadow-sm sm:px-10 sm:py-14 lg:px-16 lg:py-20">
    <div class="flex flex-col gap-3">
      <span class="text-xs font-semibold uppercase tracking-[0.3em] text-teal">
        Quiénes están detrás
      </span>
      <h2
        class="font-display text-3xl leading-tight text-navy sm:text-4xl md:text-5xl"
        style="text-wrap: balance;"
      >
        Sobre <span class="text-teal">INSOLVA</span>.
      </h2>
    </div>

    <div class="mt-10 grid gap-8 md:grid-cols-3 md:gap-10">
      {
        bloques.map((b) => (
          <div class="flex flex-col gap-3">
            <span class="font-display text-3xl text-teal">{b.n}</span>
            <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-navy/50">
              {b.label}
            </p>
            <p class="text-base leading-relaxed text-navy/80">{b.texto}</p>
          </div>
        ))
      }
    </div>

    <figure class="mt-12 border-l-2 border-teal pl-6 md:mt-16">
      <blockquote
        class="font-display text-xl leading-snug text-navy sm:text-2xl md:text-3xl"
        style="text-wrap: balance;"
      >
        Trabajamos para que nuestros clientes sean los <span class="text-teal">más
        competitivos</span> en su sector.
      </blockquote>
      <figcaption class="mt-3 text-[11px] font-medium uppercase tracking-[0.3em] text-navy/50">
        — INSOLVA
      </figcaption>
    </figure>
  </div>
</SectionContainer>
