---
import SectionContainer from '@components/SectionContainer.astro'

const pilares = [
  {
    numero: '01',
    titulo: 'Optimización de Procesos',
    resumen:
      'Rediseñamos flujos operativos para que la mercadería y el personal se muevan con menos fricción.',
    resultado: 'Menos tiempos muertos, menos errores de reposición.',
    class:
      'md:col-span-2 md:row-span-1 bg-gradient-to-br from-teal via-teal-dark to-navy text-white',
  },
  {
    numero: '02',
    titulo: 'Estandarización y Trazabilidad',
    resumen:
      'Cada procedimiento queda documentado y con registro automático de cumplimiento.',
    resultado: 'La operación no depende de quién esté en turno.',
    class:
      'md:col-span-1 md:row-span-2 bg-gradient-to-b from-navy via-navy-soft to-teal-dark text-white',
  },
  {
    numero: '03',
    titulo: 'Automatización Inteligente',
    resumen:
      'Un asistente interno que contesta dudas operativas en segundos, con el protocolo vigente.',
    resultado: 'Capacitación continua sin depender de reuniones.',
    class: 'md:col-span-2 md:row-span-1 bg-teal-light text-navy border border-teal/20',
  },
]
---

<SectionContainer id="pilares">
  <div class="flex flex-col gap-3">
    <span class="text-xs font-semibold uppercase tracking-[0.3em] text-teal">
      Propuesta
    </span>
    <h2
      class="font-display text-3xl leading-tight text-navy sm:text-4xl md:text-5xl"
      style="text-wrap: balance;"
    >
      Tres pilares. Un mismo <span class="text-teal">sistema</span>.
    </h2>
    <p class="mt-2 max-w-2xl text-base leading-relaxed text-navy/70">
      Cada pilar resuelve una pieza clara de la operación. Juntos construyen el sistema
      de gestión de calidad que ISO 9001 pide.
    </p>
  </div>

  <div class="mt-10 grid grid-cols-1 gap-4 md:grid-cols-3 md:grid-rows-2">
    {
      pilares.map((pilar) => (
        <article
          class:list={[
            'group relative flex min-h-[280px] flex-col justify-between overflow-hidden rounded-2xl p-6 transition-transform duration-500 hover:-translate-y-1 md:min-h-[320px] md:p-8',
            pilar.class,
          ]}
        >
          <div class="pointer-events-none absolute -right-6 -top-6 text-[160px] font-display leading-none opacity-10 md:text-[220px]">
            {pilar.numero}
          </div>

          <div class="relative z-10">
            <span class="text-xs font-semibold uppercase tracking-[0.3em] opacity-70">
              Pilar {pilar.numero}
            </span>
            <h3 class="mt-3 font-display text-2xl leading-tight md:text-3xl">
              {pilar.titulo}
            </h3>
            <p class="mt-3 max-w-md text-sm leading-relaxed opacity-80">
              {pilar.resumen}
            </p>
          </div>

          <div class="relative z-10 mt-6 flex flex-col gap-3 border-t border-current/20 pt-4">
            <p class="text-xs font-medium uppercase tracking-[0.2em] opacity-70">
              Resultado
            </p>
            <p class="text-sm font-semibold" style="text-wrap: balance;">
              {pilar.resultado}
            </p>
          </div>
        </article>
      ))
    }
  </div>
</SectionContainer>
