---
import Button from '@ui/Button.astro'
import WhatsApp from '@icons/WhatsApp.astro'
---

<header
  id="header"
  class="sticky top-0 left-0 right-0 z-50 mx-auto flex items-center justify-between gap-4 bg-white/80 px-4 py-3 backdrop-blur-xl md:max-w-[1400px] md:px-8 md:py-4"
>
  <div class="flex items-center gap-3 sm:gap-5">
    <a href="#" aria-label="Inicio — INSOLVA" class="flex items-center rounded-md bg-white p-1">
      <img src="/logo-insolva.png" alt="INSOLVA" class="h-8 w-auto sm:h-10" />
    </a>

    <div class="hidden items-center gap-3 border-l border-navy/10 pl-4 sm:flex">
      <span class="text-[10px] font-medium uppercase tracking-[0.25em] text-navy/50">
        Propuesta para
      </span>
      <div class="flex items-center rounded-md bg-white p-1">
        <img
          src="/logo-sanmartin.webp"
          alt="Grupo San Martín Farmacias"
          class="h-7 w-auto md:h-8"
        />
      </div>
    </div>
  </div>

  <Button
    href="https://wa.me/5492901641452?text=Hola%20INSOLVA%2C%20quiero%20saber%20m%C3%A1s%20sobre%20la%20propuesta"
    target="_blank"
    rel="noopener noreferrer"
    variant="solid"
    color="teal"
    class="!px-4 !py-2 text-xs sm:!px-6 sm:!py-3 sm:text-sm"
    ariaLabel="Hablar por WhatsApp"
  >
    <WhatsApp class="h-4 w-4" />
    <span class="hidden sm:inline">Hablemos</span>
  </Button>
</header>

<div class="mx-auto mt-2 flex max-w-[1400px] items-center gap-2 px-4 sm:hidden">
  <span class="text-[9px] font-medium uppercase tracking-[0.25em] text-navy/50">
    Propuesta para
  </span>
  <div class="flex items-center rounded-md bg-white p-1">
    <img
      src="/logo-sanmartin.webp"
      alt="Grupo San Martín Farmacias"
      class="h-5 w-auto"
    />
  </div>
</div>
